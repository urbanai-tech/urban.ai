# Urban AI Frontend — .env.example
# Copie para `.env.local` para dev ou configure no Railway para prod.
# Nunca commite valores reais.

# === Ambiente ===
# production | staging | development
# Em staging, o NEXT_PUBLIC_APP_ENV="staging" faz aparecer banner amarelo no topo
# e separar os eventos no Sentry (tag environment=staging).
NEXT_PUBLIC_APP_ENV=production

# === API do backend ===
# Prod: https://urban-ai-back-production.up.railway.app
# Staging: https://urban-ai-back-staging.up.railway.app (criar em F5C.2 item 11)
# Dev: http://localhost:10000
NEXT_PUBLIC_API_URL=https://urban-ai-back-production.up.railway.app

# === Stripe (somente publishable key no front) ===
# sk_* NUNCA vai para o front.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === NextAuth ===
# URL do app (prod: https://app.myurbanai.com; dev: http://localhost:3000)
NEXTAUTH_URL=https://app.myurbanai.com
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=
# Google OAuth (painel Google Cloud)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Sentry (opcional em dev, obrigatório em prod) ===
NEXT_PUBLIC_SENTRY_DSN=

# === Chainlit Copilot ===
# F5C.1 #12 do roadmap: migrar IP hardcoded de `next.config.ts` para essa var.
NEXT_PUBLIC_CHAINLIT_URL=http://localhost:8000

# === Analytics (F5.1 pendente) ===
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=
