# Urban AI Webscraping (Scrapy + Scrapyd) — .env.example
# Copie para `.env` local. Em produção, configurar no Railway.

# === Auth proxy (auth_proxy.py) ===
PORT=8080
# Chave que o backend precisa enviar no header x-api-key para pushar jobs no Scrapyd.
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SCRAPYD_API_KEY=

# === AWS S3 (pipeline de persistência bronze) ===
# Bucket: urbanai-data-lake (sa-east-1)
# Uso de assume-role (IAM recomendado) em vez de keys diretas:
ASSUME_ROLE_ARN=
ASSUME_ROLE_EXTERNAL_ID=

# Se preferir keys IAM diretas (fallback — menos recomendado):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=sa-east-1
# S3_BUCKET=urbanai-data-lake

# === APIs externas ===
# Ticketmaster (usado em spiders/ticket_master.py)
TICKETMASTER_API_KEY=
# Coletores opcionais. Deixar vazio desativa/faz falhar apenas o coletor especifico.
API_FOOTBALL_KEY=
SERPAPI_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
GEMINI_API_KEY=
SP_CULTURA_API_BASE=https://api.sampa.sp.gov.br/cultura
SP_CULTURA_LOOKAHEAD_DAYS=120

# Execucao local/diagnostico
LOG_LEVEL=INFO
DRY_RUN=false

# === Scripts de teste (opcional) ===
# URL do Scrapyd público (scripts/test_crawl.py)
SCRAPE_URL=https://urban-webscraping-production.up.railway.app/crawl.json

# === F6.2 Plus — Ingest no backend Urban AI (opcional) ===
# Quando setadas, a UrbanIngestPipeline envia cada evento raspado pra
# POST /events/ingest, que dedupa via dedupHash e geocodifica eventos
# sem lat/lng via cron. Sem essas envs, a pipeline é desabilitada
# silenciosamente e só o S3 (bronze layer) continua.
URBAN_API_BASE=https://api.myurbanai.com
URBAN_COLLECTOR_EMAIL=
URBAN_COLLECTOR_PASSWORD=
