# Urban AI Webscraping (Scrapy + Scrapyd) — .env.example
# Copie para `.env` local. Em produção, configurar no Railway.

# === Auth proxy (auth_proxy.py) ===
PORT=8080
# Chave que o backend precisa enviar no header x-api-key para pushar jobs no Scrapyd.
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SCRAPYD_API_KEY=

# === AWS S3 (pipeline de persistência bronze) ===
# Bucket: urbanai-data-lake (sa-east-1)
# Uso de assume-role (IAM recomendado) em vez de keys diretas:
ASSUME_ROLE_ARN=
ASSUME_ROLE_EXTERNAL_ID=

# Se preferir keys IAM diretas (fallback — menos recomendado):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=sa-east-1
# S3_BUCKET=urbanai-data-lake

# === APIs externas ===
# Ticketmaster (usado em spiders/ticket_master.py)
TICKETMASTER_API_KEY=

# === Scripts de teste (opcional) ===
# URL do Scrapyd público (scripts/test_crawl.py)
SCRAPE_URL=https://urban-webscraping-production.up.railway.app/crawl.json
