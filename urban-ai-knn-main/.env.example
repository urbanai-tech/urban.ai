# Urban AI KNN Microservice — .env.example
#
# NOTA: este microserviço está INATIVO em produção (F5C decisão pendente:
# aposentar ou reativar — ver docs/avaliacao-projeto-2026-04-16.md §3.3).
# A lógica KNN foi migrada para `urban-ai-backend-main/src/knn-engine/`.
# Mantemos este .env.example para consistência até a decisão final.

# Porta HTTP
PORT=3000

# Chave usada no header `x-api-key` para autenticar chamadas do backend
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Token Mapbox (Directions + Isochrones)
MAPBOX_TOKEN=
