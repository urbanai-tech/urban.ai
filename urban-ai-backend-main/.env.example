# Urban AI Backend — .env.example
# Copie este arquivo para `.env` (nunca commite o `.env` real)
# e preencha com os valores reais do seu ambiente.

# === Banco de dados MySQL ===
# Opção A: DATABASE_URL (formato Railway)
# DATABASE_URL=mysql://user:pass@host:port/database
#
# Opção B: variáveis individuais
DB_HOST=switchback.proxy.rlwy.net
DB_PORT=56406
DB_USER=root
DB_PASSWORD=
DB_NAME=railway

# Migrations — ver docs/runbooks/migrations-cutover.md
# Durante o cutover para migrations versionadas:
#   DB_SYNCHRONIZE=false  (prod após cutover)
#   MIGRATIONS_RUN=true   (aplica migrations no boot)
# Em dev local, pode-se manter DB_SYNCHRONIZE=true temporariamente.
DB_SYNCHRONIZE=false
MIGRATIONS_RUN=true

# === JWT ===
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRATION=3600

# === Server ===
PORT=10000
API_URL=https://urban-ai-back-production.up.railway.app
FRONT_BASE_URL=https://app.myurbanai.com

# APP_ENV identifica o ambiente lógico (production | staging | development).
# NODE_ENV fica sempre "production" em Railway (prod OU staging) para o Node rodar otimizado;
# APP_ENV é o que diferencia os dois no Sentry e no banner visual do front.
APP_ENV=production

# === APIs externas ===
# RapidAPI — hosts consumidos: airbnb19, airbnb45, airbnb-search, airbnb-income-prediction
RAPIDAPI_KEY=
# Google Maps (Geocoding + Isochrones + Distance Matrix)
GOOGLE_MAPS_API_KEY=
# HERE Maps (legado — a ser removido em F5C, verificar uso atual)
# HERE_API_KEY=
# Gemini — enriquecimento de eventos (hourly cron)
GEMINI_API_KEY=

# === SendGrid (legado, em migração para Mailersend) ===
SENDGRID_API_KEY=
SENDGRID_FORGOT_PASS_TEMPLATE=
SENDGRID_CONFIRM_EMAIL_TEMPLATE=
SENDGRID_SEND_CODE_TEMPLATE=
SENDGRID_ANALISE_PROPRIEDADE_INICIADO=
SENDGRID_ANALISE_PROPRIEDADE_FINALIZADO=
SENDGRID_ENVIO_NOTIFICATION=

# === Mailersend (transacional atual) ===
MAILERSEND_API_KEY=
MAILERSEND_FORGOT_PASS_TEMPLATE=
MAILERSEND_CONFIRM_EMAIL_TEMPLATE=
MAILERSEND_SEND_CODE_TEMPLATE=
MAILERSEND_ANALISE_PROPRIEDADE_INICIADO=
MAILERSEND_ANALISE_PROPRIEDADE_FINALIZADO=
MAILERSEND_ENVIO_NOTIFICATION=
EMAIL_SENDER=noreply@notify.myurbanai.com

RESET_PASS_URL=https://app.myurbanai.com/reset-password

# === Stripe ===
# Use chaves `sk_test_*` e `pk_test_*` em dev. Só trocar para `sk_live_*` após KYC aprovado.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (criar no Dashboard — ver docs/stripe-price-matrix.md quando F6.5 for implementada)
MENSAL_PLAN=
ANUAL_PLAN=
STARTER_MENSAL_PLAN=
STARTER_ANUAL_PLAN=
PROFISSIONAL_MENSAL_PLAN=
PROFISSIONAL_ANUAL_PLAN=
TRIAL_PERIOD_DAYS=10
SUCCESS_URL=https://app.myurbanai.com/my-plan
CANCEL_URL=https://app.myurbanai.com/plans

# === Password hashing (legado SHA-256 — migração para bcrypt prevista em F5C.2) ===
# FRONTEND_PASSWORD_SALT=
