# Etapa de build
FROM node:18 as builder

WORKDIR /usr/src/app

# Copia apenas arquivos essenciais para instalar dependências
COPY package*.json ./

# Instala o Nest CLI globalmente (opcional se não usar comandos CLI no runtime)
RUN npm install -g @nestjs/cli@10.1.18

# Instala dependências
RUN npm install

# Copia o restante do código
COPY . .

# Build da aplicação
RUN npm run build

# Etapa final (imagem mais leve)
FROM node:18-slim

WORKDIR /usr/src/app

# Copia os artefatos da build
COPY --from=builder /usr/src/app/dist ./dist
COPY --from=builder /usr/src/app/node_modules ./node_modules
COPY --from=builder /usr/src/app/package*.json ./

# Porta que a aplicação usará
EXPOSE 8080

# Render espera que a aplicação inicie com um CMD
CMD ["node", "dist/main"]
